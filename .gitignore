mobile/.DS_Store
mobile/android/
mobile/ios/
mobile/*.jks
mobile/*.p8
mobile/*.p12
mobile/*.mobileprovision
mobile/*.orig.*
mobile/coverage/

# ---- Supabase ----------------------------------------------
supabase/.branches/
supabase/.temp/

# ---- General -----------------------------------------------
.DS_Store
Thumbs.db
*.log
*.tsbuildinfo
