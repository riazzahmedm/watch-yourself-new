# ============================================================
# CineMood — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Supabase (from your Supabase project settings) ----------
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-secret-key>

# --- TMDB (from https://www.themoviedb.org/settings/api) ----
TMDB_API_KEY=<your-tmdb-api-key>

# --- Used by the mobile app (Expo) --------------------------
# These go into app.config.ts / eas.json for EAS builds.
# Only ANON_KEY is safe to ship in the app bundle.
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>
